@using UnidadResidencialProject.Models
@using UnidadResidencialProject.Services
@inject ResidenteService ResidenteService

<div class="admin-panel">
    <div class="panel-header">
        <h2 class="panel-title">👥 Gestión de Usuarios</h2>
        <button class="btn-primary" @onclick="@(() => _mostrarForm = true)">
            + Nuevo Usuario
        </button>
    </div>

    @if (_error != null)
    {
        <div style="color: #DC2626; margin-bottom: 1rem;">@_error</div>
    }

    <div class="tabla-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Documento</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Torre / Apto</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in _usuarios)
                {
                    <tr>
                        <td class="td-id">@u.UsuarioId</td>
                        <td class="td-nombre">@u.Nombre</td>
                        <td class="td-mono">@u.Documento</td>
                        <td>@u.Email</td>
                        <td><span class="rol-tag">@(u.Rol?.Nombre ?? "Sin rol")</span></td>
                        <td>
                            <span class="estado-tag @(u.Activo ? "activo" : "inactivo")">
                                @(u.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="td-mono">
                            @{
                                var ru = u.ResidentesUnidad?.FirstOrDefault();
                                var torre = ru?.Unidad?.Torre?.Nombre ?? "N/A";
                                var apto = ru?.Unidad?.Numero ?? "N/A";
                            }
                            @torre - @apto
                        </td>
                        <td>
                            @if (u.Rol?.Nombre == "Administrador")
                            {
                                <span style="font-size: 0.8rem; color: var(--text3);">🔒 Protegido</span>
                            }
                            else if (_confirmandoEliminar == u.UsuarioId)
                            {
                                <span style="font-size: 0.8rem; color: var(--text3);">¿Seguro?</span>
                                <button class="btn-toggle desactivar" style="margin-left: 4px;"
                                        @onclick="@(() => ConfirmarEliminar(u.UsuarioId))">
                                    Sí
                                </button>
                                <button class="btn-toggle activar" style="margin-left: 4px;"
                                        @onclick="@(() => _confirmandoEliminar = 0)">
                                    No
                                </button>
                            }
                            else
                            {
                                <button class="btn-toggle desactivar"
                                        @onclick="@(() => _confirmandoEliminar = u.UsuarioId)">
                                    🗑 Eliminar
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (_mostrarForm)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h2 class="modal-title">Nuevo Usuario</h2>
                <button class="modal-close" @onclick="CerrarFormulario">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" type="text" @bind="_nombre" placeholder="Nombre completo" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Documento</label>
                        <input class="form-control" type="text" @bind="_documento" placeholder="Documento" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input class="form-control" type="email" @bind="_email" placeholder="Email" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Teléfono</label>
                        <input class="form-control" type="text" @bind="_telefono" placeholder="Teléfono" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Rol</label>
                        <select class="form-control" @bind="_rolId">
                            <option value="0">— Seleccionar rol —</option>
                            @foreach (var r in Roles)
                            {
                                <option value="@r.RolId">@r.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contraseña temporal</label>
                        <input class="form-control" type="text" @bind="_password" placeholder="Contraseña" />
                    </div>
                </div>

                <!-- Separador -->
                <div style="margin: 1.2rem 0 0.5rem; border-top: 1px solid var(--border, #2a2f3a); padding-top: 1rem;">
                    <p style="font-size: 0.82rem; color: var(--text3, #888); margin: 0 0 0.75rem;">
                        🏠 <strong>Asignación de apartamento</strong> — Opcional
                    </p>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Torre</label>
                        <select class="form-control" value="@_torreId" @onchange="OnTorreChanged">
                            <option value="0">— Sin torre —</option>
                            @foreach (var t in Torres)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Apartamento</label>
                        <select class="form-control" @bind="_unidadId" disabled="@(_torreId == 0)">
                            <option value="0">— Sin apartamento —</option>
                            @foreach (var a in ApartamentosFiltrados)
                            {
                                <option value="@a.UnidadId">@a.Numero</option>
                            }
                        </select>
                    </div>
                </div>
                @if (_torreId > 0)
                {
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Tipo de residente</label>
                            <select class="form-control" @bind="_esPropietario">
                                <option value="true">Propietario</option>
                                <option value="false">Inquilino</option>
                            </select>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CerrarFormulario">Cancelar</button>
                <button class="btn-save" @onclick="CrearUsuario">Crear Usuario</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public List<RolDto> Roles { get; set; } = new();
    [Parameter] public List<TorreDto> Torres { get; set; } = new();
    [Parameter] public List<ApartamentoDto> Apartamentos { get; set; } = new();
    [Parameter] public EventCallback OnRecargar { get; set; }

    private List<UsuarioDto> _usuarios = new();
    private bool _mostrarForm = false;
    private string? _error;
    private int _confirmandoEliminar = 0;

    // Campos del formulario
    private string _nombre = "";
    private string _documento = "";
    private string _email = "";
    private string _telefono = "";
    private string _password = "";
    private int _rolId = 0;
    private int _torreId = 0;
    private int _unidadId = 0;
    private bool _esPropietario = true;

    private List<ApartamentoDto> ApartamentosFiltrados =>
        _torreId > 0 ? Apartamentos.Where(a => a.TorreId == _torreId).ToList() : new();

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarios();
    }

    private void OnTorreChanged(ChangeEventArgs e)
    {
        _torreId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _unidadId = 0; // Resetear apartamento al cambiar torre
    }

    private void CerrarFormulario()
    {
        _mostrarForm = false;
        _nombre = ""; _documento = ""; _email = ""; _telefono = "";
        _password = ""; _rolId = 0; _torreId = 0; _unidadId = 0;
        _esPropietario = true; _error = null;
    }

    private async Task CargarUsuarios()
    {
        try { _usuarios = await ResidenteService.GetUsuariosAsync(); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ConfirmarEliminar(int usuarioId)
    {
        _confirmandoEliminar = 0;
        var (ok, error) = await ResidenteService.EliminarUsuarioAsync(usuarioId);
        if (!ok) { _error = error; }
        else { await CargarUsuarios(); await OnRecargar.InvokeAsync(); }
    }

    private async Task CrearUsuario()
    {
        if (_rolId <= 0 || string.IsNullOrWhiteSpace(_nombre)) return;

        var dto = new UsuarioCreateDto
        {
            Nombre = _nombre,
            Documento = _documento,
            Email = _email,
            Telefono = _telefono,
            PasswordHash = _password,
            RolId = _rolId,
            Activo = true,
            FechaCreacion = DateTime.Now
        };

        var (ok, error) = await ResidenteService.CrearUsuarioAsync(dto);
        if (!ok) { _error = error; return; }

        // Si se seleccionó un apartamento, asignarlo
        if (_unidadId > 0)
        {
            // Obtener el usuario recién creado para obtener su ID
            var usuarios = await ResidenteService.GetUsuariosAsync();
            var nuevoUsuario = usuarios
                .OrderByDescending(u => u.UsuarioId)
                .FirstOrDefault(u => u.Email == _email || u.Nombre == _nombre);

            if (nuevoUsuario != null)
            {
                var (okAsig, errorAsig) = await ResidenteService.AsignarApartamentoAsync(
                    nuevoUsuario.UsuarioId, _unidadId, _esPropietario);

                if (!okAsig)
                {
                    _error = $"Usuario creado, pero error al asignar apartamento: {errorAsig}";
                    await CargarUsuarios();
                    await OnRecargar.InvokeAsync();
                    return;
                }
            }
        }

        CerrarFormulario();
        await CargarUsuarios();
        await OnRecargar.InvokeAsync();
    }
}
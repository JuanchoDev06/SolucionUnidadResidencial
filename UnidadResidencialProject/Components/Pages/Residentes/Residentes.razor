@page "/residentes"
@using UnidadResidencialProject.Models
@using UnidadResidencialProject.Services
@using UnidadResidencialProject.Components.Pages.Residentes.Components
@inject ResidenteService ResidenteService
@inject AuthService AuthService
@inject NavigationManager Nav


<PageTitle>Residentes — Conjunto Residencial</PageTitle>

<div class="crm-shell">

    <Sidebar />

    <main class="main-content">

        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Residentes & Apartamentos</h1>
                <span class="page-breadcrumb">Gestión de residentes por torre y unidad</span>
            </div>
            <div class="topbar-right">
                <!-- Botón de agregar removido, se agregan desde el panel de Admin -->
            </div>
        </header>

        <div class="page-body">
            @if (_cargando)
            {
                <div class="stats-row">
                    <p style="color: var(--text3); font-style: italic;">Cargando información...</p>
                </div>
            }
            else if (_error != null)
            {
                <div class="stats-row">
                    <p style="color: #DC2626;">@_error</p>
                    <button class="btn-primary" style="margin-left: 1rem;" @onclick="CargarDatos">Reintentar</button>
                </div>
            }
            else
            {
                <ResidentesTarjetas Residentes="@_residentes" Torres="@_nombresTorres" />

                <ResidentesFiltros
                    FiltroTorre="@_filtroTorre"
                    FiltroTipo="@_filtroTipo"
                    Torres="@_nombresTorres"
                    OnTorreChanged="@((t) => _filtroTorre = t)"
                    OnTipoChanged="@((t) => _filtroTipo = t)" />

                <ResidentesTabla
                    Residentes="@ResidentesFiltrados"
                    OnDesactivar="@DesactivarResidente" />
            }
        </div>

        @if (_mostrarFormulario)
        {
            <ResidentesFormulario Torres="@_torres"
                                  Apartamentos="@_apartamentos"
                                  OnGuardar="@GuardarResidente"
                                  OnCancelar="@(() => _mostrarFormulario = false)" />
        }

    </main>
</div>

@code {
    private bool _mostrarFormulario = false;
    private string _filtroTorre = "Todas";
    private string _filtroTipo = "Todos";
    private bool _inicializado = false;
    private bool _cargando = true;
    private string? _error;

    private List<UsuarioDto> _residentes = new();
    private List<TorreDto> _torres = new();
    private List<ApartamentoDto> _apartamentos = new();
    
    private List<string> _nombresTorres = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _inicializado) return;
        _inicializado = true;

        var rol = await AuthService.GetRolAsync();
        if (rol != "Administrador")
        {
            Nav.NavigateTo("/dashboard");
            return;
        }

        await CargarDatos();
        StateHasChanged();
    }

    private async Task CargarDatos()
    {
        try
        {
            _cargando = true;
            _error = null;
            
            _residentes = await ResidenteService.GetUsuariosAsync();
            _torres = await ResidenteService.GetTorresAsync();
            _apartamentos = await ResidenteService.GetApartamentosAsync();
            
            _nombresTorres = _torres.Select(t => t.Nombre).ToList();

            // Wire up relations locally if backend didn't include them
            foreach (var r in _residentes)
            {
                if (r.ResidentesUnidad != null)
                {
                    foreach (var ru in r.ResidentesUnidad)
                    {
                        if (ru.Unidad == null)
                            ru.Unidad = _apartamentos.FirstOrDefault(a => a.UnidadId == ru.UnidadId);
                        
                        if (ru.Unidad != null && ru.Unidad.Torre == null)
                            ru.Unidad.Torre = _torres.FirstOrDefault(t => t.TorreId == ru.Unidad.TorreId);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    // ── Computed ──────────────────────────────────────────
    private List<UsuarioDto> ResidentesFiltrados =>
        _residentes
            //.Where(r => _filtroTorre == "Todas" || "N/A" == _filtroTorre) // Descomentar cuando la API soporte Torres anidadas
            .Where(r => _filtroTipo  == "Todos" || string.Equals(r.Rol?.Nombre, _filtroTipo, StringComparison.OrdinalIgnoreCase))
            .OrderBy(r => r.Nombre)
            .ToList();

    // ── Acciones ──────────────────────────────────────────
    private async Task DesactivarResidente(int id)
    {
        var idx = _residentes.FindIndex(r => r.UsuarioId == id);
        if (idx >= 0)
        {
            var user = _residentes[idx];
            user.Activo = !user.Activo; // Cambiamos estado localmente
            
            var (ok, error) = await ResidenteService.ActualizarUsuarioAsync(id, user);
            if (!ok)
            {
                user.Activo = !user.Activo; // Revertimos si hay error
                _error = $"Error al actualizar estado: {error}";
            }
        }
    }

    private async Task GuardarResidente((UsuarioCreateDto Usuario, int UnidadId, bool EsPropietario) datos)
    {
        try
        {
            var (ok, error) = await ResidenteService.CrearUsuarioAsync(datos.Usuario);
            if (!ok)
            {
                _error = $"Error al registrar residente: {error}";
                _mostrarFormulario = false;
                return;
            }

            await CargarDatos();

            var nuevoUsuario = _residentes.FirstOrDefault(
                r => r.Documento == datos.Usuario.Documento);

            if (nuevoUsuario != null && datos.UnidadId > 0)
            {
                var (okAsig, errorAsig) = await ResidenteService.AsignarApartamentoAsync(
                    nuevoUsuario.UsuarioId, datos.UnidadId, datos.EsPropietario);

                if (!okAsig)
                {
                    _error = $"Usuario creado pero error al asignar apartamento: {errorAsig}";
                }
                else
                {
                    await CargarDatos();
                    
                    // Inyectar manualmente la relación en caso de que el backend no la retorne de inmediato por caché
                    var userLocal = _residentes.FirstOrDefault(r => r.UsuarioId == nuevoUsuario.UsuarioId);
                    if (userLocal != null)
                    {
                        userLocal.ResidentesUnidad ??= new List<ResidenteUnidadDto>();
                        if (!userLocal.ResidentesUnidad.Any(ru => ru.UnidadId == datos.UnidadId))
                        {
                            var nuevaRel = new ResidenteUnidadDto { UsuarioId = userLocal.UsuarioId, UnidadId = datos.UnidadId, EsPropietario = datos.EsPropietario };
                            nuevaRel.Unidad = _apartamentos.FirstOrDefault(a => a.UnidadId == datos.UnidadId);
                            if (nuevaRel.Unidad != null && nuevaRel.Unidad.Torre == null)
                                nuevaRel.Unidad.Torre = _torres.FirstOrDefault(t => t.TorreId == nuevaRel.Unidad.TorreId);
                            
                            userLocal.ResidentesUnidad.Add(nuevaRel);
                        }
                    }
                }
            }
            // Eliminado: _error = null; para no ocultar errores de asignación
        }
        catch (Exception ex)
        {
            _error = $"Error al guardar: {ex.Message}";
        }
        _mostrarFormulario = false;
    }
}
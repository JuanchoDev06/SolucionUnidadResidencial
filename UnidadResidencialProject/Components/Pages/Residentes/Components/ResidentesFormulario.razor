@using UnidadResidencialProject.Models

<div class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Registrar Residente</h2>
            <button class="modal-close" @onclick="OnCancelar">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Nombre Completo</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: María López" @bind="_nombre" />
                </div>
                <div class="form-group">
                    <label class="form-label">Documento</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: 52.123.456" @bind="_documento" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-control" type="email"
                           placeholder="Ej: maria@email.com" @bind="_email" />
                </div>
                <div class="form-group">
                    <label class="form-label">Teléfono</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: 310-111-2222" @bind="_telefono" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Torre</label>
                    <select class="form-control" @bind="_torreSeleccionada">
                        <option value="0">— Seleccionar torre —</option>
                        @foreach (var t in Torres)
                        {
                            <option value="@t.TorreId">@t.Nombre</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Apartamento</label>
                    <select class="form-control" @bind="_unidadId">
                        <option value="0">— Seleccionar apartamento —</option>
                        @foreach (var a in ApartamentosFiltrados)
                        {
                            <option value="@a.UnidadId">Apto @a.Numero</option>
                        }
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Tipo</label>
                    <select class="form-control" @bind="_tipo">
                        <option value="Propietario">Propietario</option>
                        <option value="Inquilino">Inquilino</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha de Ingreso</label>
                    <input class="form-control" type="text"
                           value="@DateTime.Now.ToString("d MMM yyyy")" readonly />
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" @onclick="OnCancelar">Cancelar</button>
            <button class="btn-save" @onclick="Guardar">Registrar Residente</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<TorreDto> Torres { get; set; } = new();
    [Parameter] public List<ApartamentoDto> Apartamentos { get; set; } = new();
    [Parameter] public EventCallback<(UsuarioCreateDto Usuario, int UnidadId, bool EsPropietario)> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private string _nombre = "";
    private string _documento = "";
    private string _email = "";
    private string _telefono = "";
    private string _tipo = "Propietario";
    private int _torreSeleccionada = 0;
    private int _unidadId = 0;

    private List<ApartamentoDto> ApartamentosFiltrados =>
        _torreSeleccionada == 0
            ? Apartamentos
            : Apartamentos.Where(a => a.TorreId == _torreSeleccionada).ToList();

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_nombre) || string.IsNullOrWhiteSpace(_documento))
            return;

        var rolId = _tipo == "Propietario" ? 4 : 5; // RolId de Propietario e Inquilino

        var nuevo = new UsuarioCreateDto
        {
            Nombre = _nombre,
            Documento = _documento,
            Email = _email,
            Telefono = _telefono,
            PasswordHash = _documento,
            RolId = rolId,
            Activo = true,
            FechaCreacion = DateTime.Now
        };

        await OnGuardar.InvokeAsync((nuevo, _unidadId, _tipo == "Propietario"));
    }
}
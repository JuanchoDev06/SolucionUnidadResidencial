@using UnidadResidencialProject.Models

<div class="tabla-panel">
    <div class="panel-header">
        <h2 class="panel-title">Listado de Residentes</h2>
        <span class="panel-sub">@Residentes.Count residentes encontrados</span>
    </div>
    <div class="tabla-wrap">
        <table class="res-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Documento</th>
                    <th>Contacto</th>
                    <th>Torre</th>
                    <th>Apartamento</th>
                    <th>Tipo (Rol)</th>
                    <th>Ingreso</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Residentes)
                {
                    <tr class="@(!r.Activo ? "row-inactivo" : "")">
                        <td class="td-id">@r.UsuarioId</td>
                        <td>
                            <div class="residente-cell">
                                <div class="avatar">@(string.IsNullOrEmpty(r.Nombre) ? "?" : r.Nombre[0].ToString())</div>
                                <span class="td-nombre">@r.Nombre</span>
                            </div>
                        </td>
                        <td class="td-mono">@r.Documento</td>
                        <td>
                            <div class="contacto-cell">
                                <span class="td-email">@r.Email</span>
                                <span class="td-tel">@r.Telefono</span>
                            </div>
                        </td>
                        <td>
                            <span class="torre-tag">
                                @(r.ResidentesUnidad?.FirstOrDefault()?.Unidad?.Torre?.Nombre ?? "N/A")
                            </span>
                        </td>
                        <td>
                            <span class="apto-tag">
                                @(r.ResidentesUnidad?.FirstOrDefault()?.Unidad?.Numero ?? "N/A")
                            </span>
                        </td>
                        <td>
                            <span class="tipo-tag @(r.Rol?.Nombre?.ToLower() == "propietario" ? "propietario" : "inquilino")">
                                @(r.Rol?.Nombre ?? "N/A")
                            </span>
                        </td>
                        <td class="td-mono">@r.FechaCreacion.ToString("d MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public List<UsuarioDto> Residentes { get; set; } = new();
    [Parameter] public EventCallback<int> OnDesactivar { get; set; }
}
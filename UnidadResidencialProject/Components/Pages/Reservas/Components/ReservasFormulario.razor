@using UnidadResidencialProject.Components.Pages.Reservas

<div class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Nueva Reserva</h2>
            <button class="modal-close" @onclick="OnCancelar">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Zona Común</label>
                    <select class="form-control" @bind="_zona">
                        <option value="">— Seleccionar zona —</option>
                        @foreach (var z in Zonas)
                        {
                            <option value="@z">@z</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha</label>
                    <input class="form-control" type="date" @bind="_fecha" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Hora Inicio</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: 9:00 AM"
                           @bind="_horaInicio" />
                </div>
                <div class="form-group">
                    <label class="form-label">Hora Fin</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: 11:00 AM"
                           @bind="_horaFin" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Residente</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: María López" @bind="_residente" />
                </div>
                <div class="form-group">
                    <label class="form-label">Apartamento</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: Apto 302" @bind="_apartamento" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Valor por Hora ($)</label>
                    <input class="form-control" type="number"
                           placeholder="0 si es gratis" @bind="_valorHora" />
                </div>
                <div class="form-group">
                    <label class="form-label">Estado Inicial</label>
                    <select class="form-control" @bind="_estado">
                        <option value="Pendiente">Pendiente</option>
                        <option value="Confirmada">Confirmada</option>
                    </select>
                </div>
            </div>

            @if (_conflicto)
            {
                <div class="alerta-conflicto">
                    ⚠️ Ya existe una reserva para esa zona en ese horario. Verifica la disponibilidad.
                </div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" @onclick="OnCancelar">Cancelar</button>
            <button class="btn-save" @onclick="Guardar">Crear Reserva</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<string> Zonas { get; set; } = new();
    [Parameter] public List<Reservas.ReservaItem> Reservas { get; set; } = new();
    [Parameter] public EventCallback<Reservas.ReservaItem> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private string _zona = "";
    private DateTime _fecha = DateTime.Today.AddDays(1);
    private string _horaInicio = "09:00";
    private string _horaFin = "11:00";
    private string _residente = "";
    private string _apartamento = "";
    private decimal _valorHora = 0;
    private string _estado = "Pendiente";
    private bool _conflicto = false;

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_zona) || string.IsNullOrWhiteSpace(_residente)) return;

        var fechaStr = _fecha.ToString("d MMM yyyy");

        _conflicto = Reservas.Any(r =>
            r.ZonaComun == _zona &&
            r.Fecha == fechaStr &&
            r.Estado != "Cancelada");

        if (_conflicto) return;

        var nueva = new Reservas.ReservaItem(
            0, _zona, _residente, _apartamento,
            fechaStr,
            _horaInicio,
            _horaFin,
            _estado, _valorHora);

        await OnGuardar.InvokeAsync(nueva);
    }
}
@using UnidadResidencialProject.Models

<div class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Nueva Reserva</h2>
            <button class="modal-close" @onclick="OnCancelar">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Zona Común</label>
                    <select class="form-control" value="@_zonaId" @onchange="OnZonaChanged">
                        <option value="0">— Seleccionar zona —</option>
                        @foreach (var z in Zonas)
                        {
                            <option value="@z.ZonaComunId">@z.Nombre</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha</label>
                    <input class="form-control" type="date" @bind="_fecha" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Hora Inicio</label>
                    <input class="form-control" type="time"
                           @bind="_horaInicioTimeOnly" />
                </div>
                <div class="form-group">
                    <label class="form-label">Hora Fin</label>
                    <input class="form-control" type="time"
                           @bind="_horaFinTimeOnly" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Residente</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: María López" @bind="_residente" />
                </div>
                <div class="form-group" style="visibility: hidden;">
                    <!-- Espacio removido de Apartamento que solicitaste -->
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Valor por Hora ($)</label>
                    <input class="form-control" type="number"
                           @bind="_valorHora" />
                </div>
                <div class="form-group">
                    <label class="form-label">Estado Inicial</label>
                    <select class="form-control" @bind="_estado">
                        <option value="Pendiente">Pendiente</option>
                        <option value="Confirmada">Confirmada</option>
                    </select>
                </div>
            </div>

            @if (_errorLocal != "")
            {
                <div class="alerta-conflicto">
                    ⚠️ @_errorLocal
                </div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" @onclick="OnCancelar">Cancelar</button>
            <button class="btn-save" @onclick="Guardar">Crear Reserva</button>
        </div>
    </div>
</div>

@code {
    [Inject] private UnidadResidencialProject.Services.AuthService AuthService { get; set; } = default!;

    [Parameter] public List<ZonaComunDto> Zonas { get; set; } = new();
    [Parameter] public List<ReservaDto> Reservas { get; set; } = new();
    [Parameter] public EventCallback<ReservaCreateDto> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private int _zonaId = 0;
    private DateTime _fecha = DateTime.Today.AddDays(1);
    private TimeOnly _horaInicioTimeOnly = new TimeOnly(9, 0);
    private TimeOnly _horaFinTimeOnly = new TimeOnly(11, 0);
    
    // UI Only
    private string _estado = "Pendiente";
    private string _residente = "";
    private decimal _valorHora = 0;
    private string _errorLocal = "";

    private void OnZonaChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            _zonaId = val;
            var zona = Zonas.FirstOrDefault(z => z.ZonaComunId == val);
            _valorHora = zona?.ValorHora ?? 0;
        }
    }

    private async Task Guardar()
    {
        if (_zonaId <= 0)
        {
            _errorLocal = "Debes seleccionar una zona común.";
            return;
        }
        
        _errorLocal = "";

        var _horaInicio = _horaInicioTimeOnly.ToTimeSpan();
        var _horaFin = _horaFinTimeOnly.ToTimeSpan();

        var userId = await AuthService.GetUserIdAsync();

        bool conflicto = Reservas.Any(r =>
            r.ZonaComunId == _zonaId &&
            r.Fecha.Date == _fecha.Date &&
            r.Estado != "Cancelada" &&
            ( (r.HoraInicio < _horaFin && r.HoraFin > _horaInicio) )
        );

        if (conflicto)
        {
            _errorLocal = "Ya existe una reserva para esa zona en este horario.";
            return;
        }

        var nueva = new ReservaCreateDto
        {
            ZonaComunId = _zonaId,
            Fecha = _fecha,
            HoraInicio = _horaInicio,
            HoraFin = _horaFin,
            UsuarioId = userId > 0 ? userId : 4
        };

        await OnGuardar.InvokeAsync(nueva);
    }
}
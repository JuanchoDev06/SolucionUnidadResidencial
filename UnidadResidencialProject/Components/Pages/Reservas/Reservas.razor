@page "/reservas"
@using UnidadResidencialProject.Models
@using UnidadResidencialProject.Services
@inject ReservaService ReservaService

<PageTitle>Reservas — Conjunto Residencial</PageTitle>

<div class="crm-shell">

    <Sidebar />

    <main class="main-content">

        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Reservas</h1>
                <span class="page-breadcrumb">Gestión de zonas comunes · Salón, BBQ, Piscina, Gimnasio</span>
            </div>
            <div class="topbar-right">
                <button class="btn-primary" @onclick="@(() => _mostrarFormulario = true)">
                    + Nueva Reserva
                </button>
            </div>
        </header>

        <div class="page-body">

            <!-- Stats row -->
            <div class="stats-row">
                <div class="stat-chip blue">
                    <span class="stat-num">@_reservas.Count</span>
                    <span class="stat-lbl">Total reservas</span>
                </div>
                <div class="stat-chip amber">
                    <span class="stat-num">@_reservas.Count(r => r.Estado == "Pendiente")</span>
                    <span class="stat-lbl">Pendientes</span>
                </div>
                <div class="stat-chip green">
                    <span class="stat-num">@_reservas.Count(r => r.Estado == "Confirmada")</span>
                    <span class="stat-lbl">Confirmadas</span>
                </div>
                <div class="stat-chip red">
                    <span class="stat-num">@_reservas.Count(r => r.Estado == "Cancelada")</span>
                    <span class="stat-lbl">Canceladas</span>
                </div>
                <div class="stat-chip teal">
                    <span class="stat-num">@_reservas.Count(r => r.Fecha.Date == DateTime.Today)</span>
                    <span class="stat-lbl">Hoy</span>
                </div>
            </div>

            <!-- Disponibilidad -->
            <ReservasDisponibilidad
                Reservas="@_reservas"
                FechaSeleccionada="@_fechaSeleccionada"
                OnFechaChanged="@((f) => _fechaSeleccionada = f)" />

            <!-- Filtros -->
            <ReservasFiltros
                FiltroEstado="@_filtroEstado"
                FiltroZona="@_filtroZona"
                Zonas="@_nombresZonas"
                OnEstadoChanged="@((e) => _filtroEstado = e)"
                OnZonaChanged="@((z) => _filtroZona = z)" />

            <!-- Tabla -->
            <ReservasTabla
                Reservas="@ReservasFiltradas"
                OnCambiarEstado="@CambiarEstado" />

        </div>

        @if (_mostrarFormulario)
        {
            <ReservasFormulario
                Zonas="@_zonas"
                Reservas="@_reservas"
                OnGuardar="@GuardarReserva"
                OnCancelar="@(() => _mostrarFormulario = false)" />
        }

    </main>
</div>

@code {
    private bool _mostrarFormulario = false;
    private string _filtroEstado = "Todos";
    private string _filtroZona = "Todas";
    private DateTime _fechaSeleccionada = DateTime.Today;

    private bool _cargando = true;
    private string? _error;

    private List<ReservaDto> _reservas = new();
    private List<ZonaComunDto> _zonas = new();
    private List<string> _nombresZonas = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            _cargando = true;
            _error = null;

            _reservas = await ReservaService.GetReservasAsync();
            _zonas = await ReservaService.GetZonasComunesAsync();
            
            _nombresZonas = _zonas.Select(z => z.Nombre).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    // ── Computed ──────────────────────────────────────────
    private List<ReservaDto> ReservasFiltradas =>
        _reservas
            .Where(r => _filtroEstado == "Todos" || r.Estado == _filtroEstado)
            .Where(r => _filtroZona == "Todas" || r.ZonaComun?.Nombre == _filtroZona)
            .OrderBy(r => r.Fecha)
            .ToList();

    // ── Acciones ──────────────────────────────────────────
    private async Task CambiarEstado((int Id, string NuevoEstado) datos)
    {
        var idx = _reservas.FindIndex(r => r.ReservaId == datos.Id);
        if (idx >= 0)
        {
            var r = _reservas[idx];
            var estadoAnterior = r.Estado;
            r.Estado = datos.NuevoEstado;

            var (ok, error) = await ReservaService.ActualizarReservaAsync(datos.Id, r);
            if (!ok)
            {
                r.Estado = estadoAnterior;
                _error = $"Error al actualizar reserva: {error}";
            }
        }
    }

    private async Task GuardarReserva(ReservaCreateDto nueva)
    {
        try
        {
            var (ok, error) = await ReservaService.CrearReservaAsync(nueva);
            if (ok)
            {
                _error = null;
                await CargarDatos(); // refresh 
            }
            else
            {
                _error = $"Error al registrar reserva: {error}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error al guardar: {ex.Message}";
        }
        _mostrarFormulario = false;
    }
}
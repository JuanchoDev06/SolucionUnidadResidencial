@page "/dashboard"
@using UnidadResidencialProject.Models
@using UnidadResidencialProject.Services
@using UnidadResidencialProject.Components.Pages.Dashboard.Components
@inject DashboardService DashboardService
@inject AuthService AuthService

<PageTitle>Dashboard — Conjunto Residencial</PageTitle>

<div class="crm-shell">

    <Sidebar />

    <main class="main-content">

        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Dashboard</h1>
                <span class="page-breadcrumb">Visión general del conjunto · Hoy, @DateTime.Now.ToString("dddd d 'de' MMMM yyyy", new System.Globalization.CultureInfo("es-CO"))</span>
            </div>
            <div class="topbar-right">
                <div class="search-box">
                    <span class="search-icon">⌕</span>
                    <input type="text" placeholder="Buscar residente, placa, paquete…" class="search-input" />
                </div>
                <div class="notif-btn">
                    <span>🔔</span>
                    <span class="notif-dot"></span>
                </div>
            </div>
        </header>

        @if (_cargando)
        {
            <div style="padding: 2rem; color: var(--text3); font-style: italic;">
                Cargando datos del dashboard…
            </div>
        }
        else
        {
            @if (_mantenimientosPendientes.Any())
            {
                <div class="alert-banner">
                    <span class="alert-icon">⚠</span>
                    <span>
                        <strong>Mantenimiento pendiente:</strong>
                        @_mantenimientosPendientes.First().TipoMantenimiento?.Nombre
                        — @_mantenimientosPendientes.First().Descripcion ·
                        <a href="/mantenimiento">Ver detalles</a>
                    </span>
                </div>
            }

            <!-- KPI CARDS -->
            <section class="kpi-grid">
                <div class="kpi-card kpi-blue">
                    <div class="kpi-top">
                        <div class="kpi-label">Residentes Activos</div>
                        <div class="kpi-icon-wrap blue">⊞</div>
                    </div>
                    <div class="kpi-value">@_totalResidentes</div>
                    <div class="kpi-meta">
                        <span class="kpi-delta up">● Activos</span> en el sistema
                    </div>
                    <div class="kpi-bar">
                        <div class="kpi-bar-fill" style="width:@(_totalResidentes > 0 ? "80%" : "0%")"></div>
                    </div>
                </div>

                <div class="kpi-card kpi-green">
                    <div class="kpi-top">
                        <div class="kpi-label">Ingresos Hoy</div>
                        <div class="kpi-icon-wrap green">⇌</div>
                    </div>
                    <div class="kpi-value">@_ingresosHoy</div>
                    <div class="kpi-meta">
                        <span class="kpi-delta up">● @_visitantesActivos activos</span> dentro ahora
                    </div>
                    <div class="kpi-bar">
                        <div class="kpi-bar-fill green"
                             style="width:@(_ingresosHoy > 0 ? Math.Min(_ingresosHoy * 5, 100) + "%" : "0%")">
                        </div>
                    </div>
                </div>

                <div class="kpi-card kpi-amber">
                    <div class="kpi-top">
                        <div class="kpi-label">Parqueadero</div>
                        <div class="kpi-icon-wrap amber">⬡</div>
                    </div>
                    <div class="kpi-value">
                        @_cuposOcupados <small>/ @_totalCupos</small>
                    </div>
                    <div class="kpi-meta">
                        <span class="kpi-delta warn">● @_visitantesParqueadero visitantes</span>
                        · @_cuposLibres disponibles
                    </div>
                    <div class="kpi-bar">
                        <div class="kpi-bar-fill amber"
                             style="width:@(_totalCupos > 0 ? (_cuposOcupados * 100 / _totalCupos) + "%" : "0%")">
                        </div>
                    </div>
                </div>

                <div class="kpi-card kpi-red">
                    <div class="kpi-top">
                        <div class="kpi-label">Paquetes Pendientes</div>
                        <div class="kpi-icon-wrap red">◻</div>
                    </div>
                    <div class="kpi-value">@_paquetesPendientes</div>
                    <div class="kpi-meta">
                        <span class="kpi-delta down">● Sin recoger</span> en portería
                    </div>
                    <div class="kpi-bar">
                        <div class="kpi-bar-fill red"
                             style="width:@(_paquetesPendientes > 0 ? Math.Min(_paquetesPendientes * 10, 100) + "%" : "0%")">
                        </div>
                    </div>
                </div>

                <div class="kpi-card kpi-teal">
                    <div class="kpi-top">
                        <div class="kpi-label">Reservas Activas</div>
                        <div class="kpi-icon-wrap teal">◷</div>
                    </div>
                    <div class="kpi-value">@_reservasActivas</div>
                    <div class="kpi-meta">
                        <span class="kpi-delta up">● @_reservasPendientes pendientes</span>
                        de confirmar
                    </div>
                    <div class="kpi-bar">
                        <div class="kpi-bar-fill teal"
                             style="width:@(_reservasActivas > 0 ? Math.Min(_reservasActivas * 10, 100) + "%" : "0%")">
                        </div>
                    </div>
                </div>

                <div class="kpi-card kpi-purple">
                    <div class="kpi-top">
                        <div class="kpi-label">Mantenimientos</div>
                        <div class="kpi-icon-wrap purple">⚙</div>
                    </div>
                    <div class="kpi-value">@_totalMantenimientos</div>
                    <div class="kpi-meta">
                        <span class="kpi-delta warn">● @_mantenimientosPendientes.Count pendientes</span>
                    </div>
                    <div class="kpi-bar">
                        <div class="kpi-bar-fill purple"
                             style="width:@(_totalMantenimientos > 0 ? Math.Min(_totalMantenimientos * 10, 100) + "%" : "0%")">
                        </div>
                    </div>
                </div>
            </section>

            <!-- MID ROW -->
            <section class="mid-grid">
                <div class="panel activity-panel">
                    <div class="panel-header">
                        <h2 class="panel-title">Actividad Reciente</h2>
                        <a href="/ingresos" class="panel-link">Ver todo →</a>
                    </div>
                    <div class="activity-list">
                        @foreach (var item in _activityFeed)
                        {
                            <div class="activity-item">
                                <div class="act-dot @item.Color"></div>
                                <div class="act-body">
                                    <span class="act-title">@item.Title</span>
                                    <span class="act-sub">@item.Sub</span>
                                </div>
                                <span class="act-time">@item.Time</span>
                            </div>
                        }
                        @if (!_activityFeed.Any())
                        {
                            <p style="color:var(--text3); font-style:italic; padding: 1rem 0;">
                                Sin actividad reciente
                            </p>
                        }
                    </div>
                </div>

                <div class="panel parking-panel">
                    <div class="panel-header">
                        <h2 class="panel-title">Parqueadero — Cupos</h2>
                        <a href="/parqueadero" class="panel-link">Gestionar →</a>
                    </div>
                    <div class="parking-legend">
                        <span class="leg-dot free"></span> Disponible
                        <span class="leg-dot occ"></span> Residente
                        <span class="leg-dot vis"></span> Visitante
                    </div>
                    <div class="parking-grid">
                        @foreach (var cupo in _parqueaderos.Take(30))
                        {
                            var visitanteActivo = _visitantes.Any(v =>
                            v.ParqueaderoId == cupo.ParqueaderoId &&
                            v.FechaHoraSalida == null);
                            var state = visitanteActivo ? "vis"
                            : cupo.UnidadId != null ? "occ"
                            : "free";
                            <div class="p-slot @state" title="Cupo @cupo.Numero">
                                <span class="slot-num">@cupo.Numero</span>
                            </div>
                        }
                    </div>
                    <div class="parking-summary">
                        <div class="ps-item">
                            <span class="ps-num green">@_cuposLibres</span>
                            <span class="ps-lbl">Libres</span>
                        </div>
                        <div class="ps-item">
                            <span class="ps-num amber">@_cuposOcupados</span>
                            <span class="ps-lbl">Residentes</span>
                        </div>
                        <div class="ps-item">
                            <span class="ps-num red">@_visitantesParqueadero</span>
                            <span class="ps-lbl">Visitantes</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- BOTTOM ROW -->
            <section class="bottom-grid">
                <div class="panel">
                    <div class="panel-header">
                        <h2 class="panel-title">Próximas Reservas</h2>
                        <a href="/reservas" class="panel-link">Ver todas →</a>
                    </div>
                    <table class="mini-table">
                        <thead>
                            <tr><th>Zona</th><th>Residente</th><th>Fecha</th><th>Estado</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var r in _proximasReservas)
                            {
                                <tr>
                                    <td><span class="zone-tag">@r.ZonaComun?.Nombre</span></td>
                                    <td>@(r.Usuario?.Nombre ?? "N/A")</td>
                                    <td>@r.Fecha.ToString("d MMM yyyy")</td>
                                    <td>
                                        <span class="status-tag @(r.Estado == "Confirmada" ? "confirmed" : "pending")">
                                            @r.Estado
                                        </span>
                                    </td>
                                </tr>
                            }
                            @if (!_proximasReservas.Any())
                            {
                                <tr>
                                    <td colspan="4" style="color:var(--text3); font-style:italic; padding:.75rem;">
                                        Sin reservas próximas
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="panel">
                    <div class="panel-header">
                        <h2 class="panel-title">Mantenimientos</h2>
                        <a href="/mantenimiento" class="panel-link">Ver todos →</a>
                    </div>
                    <div class="maint-list">
                        @foreach (var m in _mantenimientosPendientes.Take(3))
                        {
                            <div class="maint-item @(m.Estado == "Pendiente" ? "urgent" : "")">
                                <div class="maint-left">
                                    <span class="maint-type">
                                        @(m.TipoMantenimiento?.Nombre ?? "General")
                                    </span>
                                    <span class="maint-desc">
                                        @(m.Descripcion ?? "Sin descripción")
                                        @if (m.ZonaComun != null)
                                        {
                                            <text> — @m.ZonaComun.Nombre</text>
                                        }
                                    </span>
                                </div>
                                <div class="maint-right">
                                    <span class="maint-date">
                                        @m.Fecha.ToString("d MMM")
                                    </span>
                                    <span class="urgency-tag @(m.Estado == "Pendiente" ? "urgent" : "normal")">
                                        @(m.Estado ?? "Pendiente")
                                    </span>
                                </div>
                            </div>
                        }
                        @if (!_mantenimientosPendientes.Any())
                        {
                            <p style="color:var(--text3); font-style:italic; padding: 1rem 0;">
                                Sin mantenimientos pendientes
                            </p>
                        }
                    </div>
                </div>

                <div class="panel">
                    <div class="panel-header">
                        <h2 class="panel-title">Mensajería</h2>
                        <a href="/mensajeria" class="panel-link">Ver todo →</a>
                    </div>
                    <div class="pkg-list">
                        @foreach (var p in _paquetesRecientes.Take(3))
                        {
                            var entregado = p.FechaEntrega != null;
                            <div class="pkg-item">
                                <div class="pkg-icon">@(entregado ? "✉️" : "📦")</div>
                                <div class="pkg-body">
                                    <span class="pkg-name">
                                        Apto @(p.Unidad?.Numero ?? "?")
                                    </span>
                                    <span class="pkg-company">
                                        @(p.Empresa ?? "Sin empresa") · Guía @(p.Guia ?? "N/A")
                                    </span>
                                </div>
                                <div class="pkg-right">
                                    <span class="pkg-date">
                                        @p.FechaRecepcion.ToString("d MMM HH:mm")
                                    </span>
                                    <span class="pkg-status @(entregado ? "delivered" : "waiting")">
                                        @(entregado ? "Entregado" : "Sin recoger")
                                    </span>
                                </div>
                            </div>
                        }
                        @if (!_paquetesRecientes.Any())
                        {
                            <p style="color:var(--text3); font-style:italic; padding: 1rem 0;">
                                Sin paquetes recientes
                            </p>
                        }
                    </div>
                </div>
            </section>
        }

    </main>
</div>

@code {
    private bool _cargando = true;
    private bool _inicializado = false;

    // ── Datos crudos de la API ────────────────────────────
    private List<UsuarioDto> _usuarios = new();
    private List<IngresoDto> _ingresos = new();
    private List<ParqueaderoDto> _parqueaderos = new();
    private List<ParqueaderoVisitanteDto> _visitantes = new();
    private List<MensajeriaDto> _mensajeria = new();
    private List<ReservaDto> _reservas = new();
    private List<MantenimientoDto> _mantenimientos = new();

    // ── KPIs computados ───────────────────────────────────
    private int _totalResidentes => _usuarios.Count(u => u.Activo);
    private int _ingresosHoy => _ingresos.Count(i => i.FechaHoraIngreso.Date == DateTime.Today);
    private int _visitantesActivos => _ingresos.Count(i => i.FechaHoraSalida == null);
    private int _totalCupos => _parqueaderos.Count;
    private int _cuposLibres => _parqueaderos.Count(p => p.UnidadId == null && !_visitantes.Any(v => v.ParqueaderoId == p.ParqueaderoId && v.FechaHoraSalida == null));
    private int _cuposOcupados => _parqueaderos.Count(p => p.UnidadId != null);
    private int _visitantesParqueadero => _visitantes.Count(v => v.FechaHoraSalida == null);
    private int _paquetesPendientes => _mensajeria.Count(m => m.FechaEntrega == null);
    private int _reservasActivas => _reservas.Count(r => r.Estado != "Cancelada");
    private int _reservasPendientes => _reservas.Count(r => r.Estado == "Pendiente");
    private int _totalMantenimientos => _mantenimientos.Count;

    // ── Listas para secciones ─────────────────────────────
    private List<MantenimientoDto> _mantenimientosPendientes =>
        _mantenimientos
            .Where(m => m.Estado == "Pendiente" || m.Estado == null)
            .OrderBy(m => m.Fecha)
            .ToList();

    private List<ReservaDto> _proximasReservas =>
        _reservas
            .Where(r => r.Fecha.Date >= DateTime.Today && r.Estado != "Cancelada")
            .OrderBy(r => r.Fecha)
            .Take(4)
            .ToList();

    private List<MensajeriaDto> _paquetesRecientes =>
        _mensajeria
            .OrderByDescending(m => m.FechaRecepcion)
            .Take(3)
            .ToList();

    // ── Actividad reciente desde ingresos reales ──────────
    private List<ActivityItem> _activityFeed =>
        _ingresos
            .OrderByDescending(i => i.FechaHoraIngreso)
            .Take(8)
            .Select(i => new ActivityItem(
                i.Tipo == "Residente" ? "Ingreso Residente"
                : i.Tipo == "Visitante" ? "Visitante registrado"
                : "Proveedor registrado",
                $"{i.NombrePersona} · Doc. {i.Documento}",
                i.FechaHoraIngreso.ToString("hh:mm tt"),
                i.Tipo == "Residente" ? "blue"
                : i.Tipo == "Visitante" ? "green"
                : "amber"
            ))
            .ToList();

    // ── Ciclo de vida ─────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _inicializado) return;
        _inicializado = true;
        await CargarDatos();
        StateHasChanged();
    }

    private async Task CargarDatos()
    {
        try
        {
            _cargando = true;
            _usuarios = await DashboardService.GetUsuariosAsync();
            _ingresos = await DashboardService.GetIngresosAsync();
            _parqueaderos = await DashboardService.GetParqueaderosAsync();
            _visitantes = await DashboardService.GetVisitantesAsync();
            _mensajeria = await DashboardService.GetMensajeriaAsync();
            _reservas = await DashboardService.GetReservasAsync();
            _mantenimientos = await DashboardService.GetMantenimientosAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando dashboard: {ex.Message}");
        }
        finally
        {
            _cargando = false;
        }
    }

    private record ActivityItem(string Title, string Sub, string Time, string Color);
}
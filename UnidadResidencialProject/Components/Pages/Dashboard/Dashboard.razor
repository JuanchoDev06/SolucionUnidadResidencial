@page "/dashboard"
@using System.Timers
@using UnidadResidencialProject.Components.Pages.Dashboard.Components


<PageTitle>Dashboard — Conjunto Residencial</PageTitle>

<div class="crm-shell">

    <Sidebar />

    <main class="main-content">

        <!-- TOP BAR -->
        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Dashboard</h1>
                <span class="page-breadcrumb">Visión general del conjunto · Hoy, @DateTime.Now.ToString("dddd d 'de' MMMM yyyy", new System.Globalization.CultureInfo("es-CO"))</span>
            </div>
            <div class="topbar-right">
                <div class="search-box">
                    <span class="search-icon">⌕</span>
                    <input type="text" placeholder="Buscar residente, placa, paquete…" class="search-input" />
                </div>
                <div class="notif-btn">
                    <span>🔔</span>
                    <span class="notif-dot"></span>
                </div>
            </div>
        </header>

        <!-- ALERT BANNER -->
        <div class="alert-banner">
            <span class="alert-icon">⚠</span>
            <span><strong>Mantenimiento programado:</strong> Ascensor Torre B — Mañana 8:00 AM a 12:00 PM · <a href="/mantenimiento">Ver detalles</a></span>
            <button class="alert-close">✕</button>
        </div>

        <!-- KPI CARDS -->
        <section class="kpi-grid">
            <div class="kpi-card kpi-blue">
                <div class="kpi-top">
                    <div class="kpi-label">Residentes Activos</div>
                    <div class="kpi-icon-wrap blue">⊞</div>
                </div>
                <div class="kpi-value">248</div>
                <div class="kpi-meta"><span class="kpi-delta up">↑ +3</span> esta semana · 86 unidades ocupadas</div>
                <div class="kpi-bar"><div class="kpi-bar-fill" style="width:82%"></div></div>
            </div>

            <div class="kpi-card kpi-green">
                <div class="kpi-top">
                    <div class="kpi-label">Ingresos Hoy</div>
                    <div class="kpi-icon-wrap green">⇌</div>
                </div>
                <div class="kpi-value">134</div>
                <div class="kpi-meta"><span class="kpi-delta up">↑ 12</span> vs. ayer · 22 visitantes activos</div>
                <div class="kpi-bar"><div class="kpi-bar-fill green" style="width:67%"></div></div>
            </div>

            <div class="kpi-card kpi-amber">
                <div class="kpi-top">
                    <div class="kpi-label">Parqueadero</div>
                    <div class="kpi-icon-wrap amber">⬡</div>
                </div>
                <div class="kpi-value">23 <small>/ 30</small></div>
                <div class="kpi-meta"><span class="kpi-delta warn">● 1 visitantes</span> · 23 disponibles</div>
                <div class="kpi-bar"><div class="kpi-bar-fill amber" style="width:68%"></div></div>
            </div>

            <div class="kpi-card kpi-red">
                <div class="kpi-top">
                    <div class="kpi-label">Paquetes Pendientes</div>
                    <div class="kpi-icon-wrap red">◻</div>
                </div>
                <div class="kpi-value">7</div>
                <div class="kpi-meta"><span class="kpi-delta down">● Sin recoger</span> · más de 48 horas</div>
                <div class="kpi-bar"><div class="kpi-bar-fill red" style="width:35%"></div></div>
            </div>

            <div class="kpi-card kpi-teal">
                <div class="kpi-top">
                    <div class="kpi-label">Reservas Activas</div>
                    <div class="kpi-icon-wrap teal">◷</div>
                </div>
                <div class="kpi-value">5</div>
                <div class="kpi-meta"><span class="kpi-delta up">↑ Salón social</span> · hoy 6:00 PM</div>
                <div class="kpi-bar"><div class="kpi-bar-fill teal" style="width:50%"></div></div>
            </div>

            <div class="kpi-card kpi-purple">
                <div class="kpi-top">
                    <div class="kpi-label">Mantenimientos</div>
                    <div class="kpi-icon-wrap purple">⚙</div>
                </div>
                <div class="kpi-value">3</div>
                <div class="kpi-meta"><span class="kpi-delta warn">● 1 urgente</span> · Ascensor Torre B</div>
                <div class="kpi-bar"><div class="kpi-bar-fill purple" style="width:30%"></div></div>
            </div>
        </section>

        <!-- MID ROW -->
        <section class="mid-grid">
            <div class="panel activity-panel">
                <div class="panel-header">
                    <h2 class="panel-title">Actividad Reciente</h2>
                    <a href="/ingresos" class="panel-link">Ver todo →</a>
                </div>
                <div class="activity-list">
                    @foreach (var item in _activityFeed)
                    {
                        <div class="activity-item">
                            <div class="act-dot @item.Color"></div>
                            <div class="act-body">
                                <span class="act-title">@item.Title</span>
                                <span class="act-sub">@item.Sub</span>
                            </div>
                            <span class="act-time">@item.Time</span>
                        </div>
                    }
                </div>
            </div>

            <div class="panel parking-panel">
                <div class="panel-header">
                    <h2 class="panel-title">Parqueadero — Planta 1</h2>
                    <a href="/parqueadero" class="panel-link">Gestionar →</a>
                </div>
                <div class="parking-legend">
                    <span class="leg-dot free"></span> Disponible
                    <span class="leg-dot occ"></span> Ocupado
                    <span class="leg-dot vis"></span> Visitante
                </div>
                <div class="parking-grid">
                    @for (int i = 0; i < 30; i++)
                    {
                        var state = _parkingStates[i];
                        <div class="p-slot @state" title="Cupo @(i+1)">
                            <span class="slot-num">@(i+1)</span>
                        </div>
                    }
                </div>
                <div class="parking-summary">
                    <div class="ps-item"><span class="ps-num green">7</span><span class="ps-lbl">Libres</span></div>
                    <div class="ps-item"><span class="ps-num amber">23</span><span class="ps-lbl">Ocupados</span></div>
                    <div class="ps-item"><span class="ps-num red">1</span><span class="ps-lbl">Visitantes</span></div>
                </div>
            </div>
        </section>

        <!-- BOTTOM ROW -->
        <section class="bottom-grid">
            <div class="panel">
                <div class="panel-header">
                    <h2 class="panel-title">Próximas Reservas</h2>
                    <a href="/reservas" class="panel-link">Ver todas →</a>
                </div>
                <table class="mini-table">
                    <thead>
                        <tr><th>Zona</th><th>Residente</th><th>Fecha</th><th>Estado</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="zone-tag salon">Salón Social</span></td>
                            <td>María López · Apto 302</td><td>Hoy 6:00 PM</td>
                            <td><span class="status-tag confirmed">Confirmada</span></td>
                        </tr>
                        <tr>
                            <td><span class="zone-tag bbq">BBQ</span></td>
                            <td>Carlos Ríos · Apto 501</td><td>Mañana 12:00 PM</td>
                            <td><span class="status-tag pending">Pendiente</span></td>
                        </tr>
                        <tr>
                            <td><span class="zone-tag gym">Gimnasio</span></td>
                            <td>Ana Torres · Apto 104</td><td>Vie 22 Feb</td>
                            <td><span class="status-tag confirmed">Confirmada</span></td>
                        </tr>
                        <tr>
                            <td><span class="zone-tag piscina">Piscina</span></td>
                            <td>Pedro Gómez · Apto 207</td><td>Sáb 23 Feb</td>
                            <td><span class="status-tag confirmed">Confirmada</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="panel">
                <div class="panel-header">
                    <h2 class="panel-title">Mantenimientos</h2>
                    <a href="/mantenimiento" class="panel-link">Ver todos →</a>
                </div>
                <div class="maint-list">
                    <div class="maint-item urgent">
                        <div class="maint-left">
                            <span class="maint-type">Ascensor</span>
                            <span class="maint-desc">Revisión técnica — Torre B</span>
                        </div>
                        <div class="maint-right">
                            <span class="maint-date">Mañana</span>
                            <span class="urgency-tag urgent">Urgente</span>
                        </div>
                    </div>
                    <div class="maint-item">
                        <div class="maint-left">
                            <span class="maint-type">Jardín</span>
                            <span class="maint-desc">Poda y fertilización zonas verdes</span>
                        </div>
                        <div class="maint-right">
                            <span class="maint-date">25 Feb</span>
                            <span class="urgency-tag normal">Programado</span>
                        </div>
                    </div>
                    <div class="maint-item">
                        <div class="maint-left">
                            <span class="maint-type">Parque Infantil</span>
                            <span class="maint-desc">Inspección de equipos y pintura</span>
                        </div>
                        <div class="maint-right">
                            <span class="maint-date">1 Mar</span>
                            <span class="urgency-tag normal">Programado</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel">
                <div class="panel-header">
                    <h2 class="panel-title">Mensajería</h2>
                    <a href="/mensajeria" class="panel-link">Ver todo →</a>
                </div>
                <div class="pkg-list">
                    <div class="pkg-item">
                        <div class="pkg-icon">📦</div>
                        <div class="pkg-body">
                            <span class="pkg-name">Apto 302 — María López</span>
                            <span class="pkg-company">Amazon · Guía #7821934</span>
                        </div>
                        <div class="pkg-right">
                            <span class="pkg-date">Hoy 10:15 AM</span>
                            <span class="pkg-status waiting">Sin recoger</span>
                        </div>
                    </div>
                    <div class="pkg-item">
                        <div class="pkg-icon">📦</div>
                        <div class="pkg-body">
                            <span class="pkg-name">Apto 501 — Carlos Ríos</span>
                            <span class="pkg-company">Rappi · Guía #5541002</span>
                        </div>
                        <div class="pkg-right">
                            <span class="pkg-date">Ayer 3:40 PM</span>
                            <span class="pkg-status waiting">Sin recoger</span>
                        </div>
                    </div>
                    <div class="pkg-item">
                        <div class="pkg-icon">✉️</div>
                        <div class="pkg-body">
                            <span class="pkg-name">Apto 104 — Ana Torres</span>
                            <span class="pkg-company">Correos Nacionales</span>
                        </div>
                        <div class="pkg-right">
                            <span class="pkg-date">18 Feb</span>
                            <span class="pkg-status delivered">Entregado</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>
</div>

@code {
    private List<ActivityItem> _activityFeed = new()
    {
        new("Ingreso Residente",   "Juan Pérez · Apto 205 · Portería principal", "10:42 AM", "blue"),
        new("Visitante registrado","Luis Morales · Documento 80.123.456",        "10:38 AM", "green"),
        new("Paquete recibido",    "Amazon → Apto 302 · Guía 7821934",           "10:15 AM", "amber"),
        new("Reserva confirmada",  "Salón Social → María López · Apto 302",      "09:55 AM", "teal"),
        new("Salida registrada",   "Camión de trasteo · Placa ABC-123",           "09:30 AM", "gray"),
        new("Parqueadero Vis.",    "Placa XYZ-987 · Cupo 28 asignado",           "09:12 AM", "purple"),
        new("Ingreso Residente",   "Sandra Gil · Apto 410 · Portería lateral",   "08:50 AM", "blue"),
        new("Alerta Mant.",        "Ascensor Torre B · Técnico en camino",        "08:20 AM", "red"),
    };

    private string[] _parkingStates = Array.Empty<string>();

    protected override void OnInitialized()
    {
        var rng = new Random(42);
        _parkingStates = Enumerable.Range(0, 30).Select(i =>
        {
            var r = rng.NextDouble();
            if (r < 0.60) return "occ";
            if (r < 0.70) return "vis";
            return "free";
        }).ToArray();
    }

    private record ActivityItem(string Title, string Sub, string Time, string Color);
}
@inject AuthService AuthService
@inject NavigationManager Nav


<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon">
            <svg viewBox="0 0 32 32" fill="none">
                <rect x="2" y="12" width="10" height="18" rx="1" fill="currentColor" opacity=".9" />
                <rect x="14" y="6" width="16" height="24" rx="1" fill="currentColor" />
                <rect x="17" y="14" width="4" height="4" rx=".5" fill="white" opacity=".6" />
                <rect x="23" y="14" width="4" height="4" rx=".5" fill="white" opacity=".6" />
                <rect x="17" y="20" width="4" height="4" rx=".5" fill="white" opacity=".6" />
                <rect x="23" y="20" width="4" height="4" rx=".5" fill="white" opacity=".6" />
            </svg>
        </div>
        <div class="brand-text">
            <span class="brand-name">ResidenciaPro</span>
            <span class="brand-sub">Torre Laureles · NIT 900.123.456</span>
        </div>
    </div>


    <nav class="sidebar-nav">

        @if (_esAdmin || _esVigilante)
        {
        <div class="nav-section-label">General</div>
            <a class="nav-item" href="/dashboard">
                <span class="nav-icon">⊞</span>
                <span>Dashboard</span>
            </a>
        }

        @if (_esAdmin)
        {
            <a class="nav-item" href="/residentes">
                <span class="nav-icon">◈</span>
                <span>Residentes</span>
            </a>
            <a class="nav-item" href="/residentes">
                <span class="nav-icon">▦</span>
                <span>Apartamentos</span>
            </a>
        }

        <div class="nav-section-label" style="margin-top:1.5rem">Operaciones</div>

        @if (_esAdmin || _esVigilante)
        {
            <a class="nav-item" href="/ingresos">
                <span class="nav-icon">⇌</span>
                <span>Control de Acceso</span>
            </a>
            <a class="nav-item" href="/parqueadero">
                <span class="nav-icon">⬡</span>
                <span>Parqueadero</span>
            </a>
        }


        @if (_esAdmin || _esVigilante)
        {
            <a class="nav-item" href="/ingresos">
                <span class="nav-icon">⇌</span>
                <span>Control de Acceso</span>
            </a>
            <a class="nav-item" href="/parqueadero">
                <span class="nav-icon">⬡</span>
                <span>Parqueadero</span>
            </a>
        }

        <a class="nav-item" href="/mensajeria">
            <span class="nav-icon">◻</span>
            <span>Mensajería</span>
        </a>


        <a class="nav-item" href="/reservas">
            <span class="nav-icon">◷</span>
            <span>Reservas</span>
        </a>

        @if (_esAdmin || _esVigilante)
        {
            <div class="nav-section-label" style="margin-top:1.5rem">Administración</div>
            <a class="nav-item" href="/mantenimiento">
                <span class="nav-icon">⚙</span>
                <span>Mantenimiento</span>
            </a>
        }

        @if (_esAdmin)
        {
            <a class="nav-item" href="/admin">
                <span class="nav-icon">🛡</span>
                <span>Administración</span>
            </a>
            <a class="nav-item" href="/reportes">
                <span class="nav-icon">📊</span>
                <span>Reportes</span>
            </a>
        }

    </nav>


    <div class="sidebar-footer">
        <div class="user-chip">
            <div class="user-avatar">@_inicial</div>
            <div class="user-avatar">@_inicial</div>
            <div class="user-info">
                <span class="user-name">@_nombreRol</span>
                <span class="user-role">@_rol</span>
                <span class="user-name">@_nombreRol</span>
                <span class="user-role">@_rol</span>
            </div>
            <button class="logout-btn" @onclick="CerrarSesion" title="Cerrar sesión">⏻</button>
        </div>
    </div>
</aside>

@code {
    private bool _esAdmin = false;
    private bool _esVigilante = false;
    private string _rol = "";
    private string _nombreRol = "";
    private string _inicial = "?";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _rol = await AuthService.GetRolAsync();
        _esAdmin = _rol == "Administrador";
        _esVigilante = _rol == "Vigilante";
        _nombreRol = _esAdmin ? "Administrador" : _esVigilante ? "Vigilante" : "Residente";
        _inicial = _nombreRol.Length > 0 ? _nombreRol[0].ToString().ToUpper() : "?";
        StateHasChanged();
    }

    private async Task CerrarSesion()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
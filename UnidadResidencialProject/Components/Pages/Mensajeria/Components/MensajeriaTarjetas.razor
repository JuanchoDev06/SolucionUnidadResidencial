@using UnidadResidencialProject.Components.Pages.Mensajeria
@using UnidadResidencialProject.Models

<div class="tarjetas-row">
    <div class="tarjeta-stat blue">
        <div class="ts-icon">📦</div>
        <div class="ts-body">
            <span class="ts-num">@Paquetes.Count</span>
            <span class="ts-lbl">Total paquetes</span>
        </div>
    </div>
    <div class="tarjeta-stat amber">
        <div class="ts-icon">⏳</div>
        <div class="ts-body">
            <span class="ts-num">@Paquetes.Count(p => p.FechaEntrega == null)</span>
            <span class="ts-lbl">Pendientes</span>
        </div>
    </div>
    <div class="tarjeta-stat green">
        <div class="ts-icon">✅</div>
        <div class="ts-body">
            <span class="ts-num">@Paquetes.Count(p => p.FechaEntrega != null)</span>
            <span class="ts-lbl">Entregados</span>
        </div>
    </div>
    <div class="tarjeta-stat red">
        <div class="ts-icon">🚨</div>
        <div class="ts-body">
            <span class="ts-num">@Paquetes.Count(p => p.FechaEntrega == null && EsMasDe48h(p.FechaRecepcion))</span>
            <span class="ts-lbl">Más de 48h sin recoger</span>
        </div>
    </div>
    <div class="tarjeta-stat teal">
        <div class="ts-icon">📬</div>
        <div class="ts-body">
            <span class="ts-num">@Paquetes.Count(p => p.FechaRecepcion.Date == DateTime.Today)</span>
            <span class="ts-lbl">Recibidos hoy</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<MensajeriaDto> Paquetes { get; set; } = new();

    private bool EsMasDe48h(DateTime fecha) =>
        (DateTime.Now - fecha).TotalHours > 48;
}
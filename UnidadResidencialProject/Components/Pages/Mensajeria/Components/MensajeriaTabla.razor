@using UnidadResidencialProject.Components.Pages.Mensajeria

<div class="tabla-panel">
    <div class="panel-header">
        <h2 class="panel-title">Registro de Paquetes</h2>
        <span class="panel-sub">@Paquetes.Count registros encontrados</span>
    </div>
    <div class="tabla-wrap">
        <table class="msg-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tipo</th>
                    <th>Empresa</th>
                    <th>Guía</th>
                    <th>Apartamento</th>
                    <th>Residente</th>
                    <th>Recepción</th>
                    <th>Entrega</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Paquetes)
                {
                    <tr class="@(GetEstado(p) == "Pendiente" ? "row-pendiente" : "")">
                        <td class="td-id">@p.MensajeriaId</td>
                        <td><span class="tipo-icon">@GetIcono(p)</span></td>
                        <td class="td-empresa">@CleanEmpresa(p.Empresa)</td>
                        <td class="td-mono">@GetGuiaLimpia(p.Guia)</td>
                        <td class="td-mono">@(p.Unidad?.Torre?.Nombre) @p.Unidad?.Numero</td>
                        <td class="td-nombre">@GetResidente(p.Guia)</td>
                        <td class="td-mono">@p.FechaRecepcion.ToString("d MMM h:mm tt")</td>
                        <td class="td-mono">@(p.FechaEntrega?.ToString("d MMM h:mm tt") ?? "—")</td>
                        <td>
                            <span class="estado-tag @(GetEstado(p) == "Pendiente" ? "pendiente" : "entregado")">
                                @GetEstado(p)
                            </span>
                        </td>
                        <td>
                            @if (GetEstado(p) == "Pendiente")
                            {
                                <button class="btn-entregar"
                                        @onclick="@(() => OnMarcarEntregado.InvokeAsync(p.MensajeriaId))">
                                    ✓ Entregar
                                </button>
                            }
                            else
                            {
                                <span class="td-ok">✓</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public List<MensajeriaDto> Paquetes { get; set; } = new();
    [Parameter] public EventCallback<int> OnMarcarEntregado { get; set; }

    private string GetEstado(MensajeriaDto p) => p.FechaEntrega == null ? "Pendiente" : "Entregado";

    // Extrae el nombre del residente del campo Guia (formato: "Nombre||Codigo" o solo "Codigo")
    private string GetResidente(string? guia)
    {
        if (string.IsNullOrEmpty(guia)) return "—";
        var partes = guia.Split("||", 2);
        return partes.Length == 2 ? partes[0] : "—";
    }

    // Extrae solo el código de guía limpio del campo Guia
    private string GetGuiaLimpia(string? guia)
    {
        if (string.IsNullOrEmpty(guia)) return "—";
        var partes = guia.Split("||", 2);
        return partes.Length == 2 ? partes[1] : guia;
    }

    // Extrae dinámicamente el icono basado en el prefijo guardado en la Empresa
    private string GetIcono(MensajeriaDto p)
    {
        if (string.IsNullOrEmpty(p.Empresa)) return "📦";
        if (p.Empresa.StartsWith("[Sobre]")) return "✉️";
        if (p.Empresa.StartsWith("[Correspondencia]")) return "📄";
        return "📦"; // Default Paquete
    }

    private string CleanEmpresa(string? empresa)
    {
        if (string.IsNullOrEmpty(empresa)) return "";
        if (empresa.StartsWith("[Sobre] ")) return empresa.Substring(8);
        if (empresa.StartsWith("[Paquete] ")) return empresa.Substring(10);
        if (empresa.StartsWith("[Correspondencia] ")) return empresa.Substring(18);
        return empresa;
    }
}
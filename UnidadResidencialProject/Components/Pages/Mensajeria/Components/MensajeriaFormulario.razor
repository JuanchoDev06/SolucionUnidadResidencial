@using UnidadResidencialProject.Models

<div class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Registrar Paquete</h2>
            <button class="modal-close" @onclick="OnCancelar">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Empresa / Remitente</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: Amazon, DHL, Rappi..." @bind="_empresa" />
                </div>
                <div class="form-group">
                    <label class="form-label">Número de Guía</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: AMZ-7821934" @bind="_guia" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Apartamento Destinatario</label>
                    <select class="form-control" @bind="_unidadId">
                        <option value="0">— Seleccionar Apto —</option>
                        @foreach (var a in Apartamentos)
                        {
                            <option value="@a.UnidadId">@(a.Torre?.Nombre) - Apto @a.Numero</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Nombre del Residente</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: María López" @bind="_residente" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Tipo</label>
                    <select class="form-control" @bind="_tipo">
                        <option value="Paquete">📦 Paquete</option>
                        <option value="Sobre">✉️ Sobre</option>
                        <option value="Correspondencia">📄 Correspondencia</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha de Recepción</label>
                    <input class="form-control" type="date" @bind="_fechaRecepcion" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Estado Inicial</label>
                    <select class="form-control" @bind="_estado">
                        <option value="Pendiente">Pendiente</option>
                        <option value="Entregado">Entregado</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" @onclick="OnCancelar">Cancelar</button>
            <button class="btn-save" @onclick="Guardar">Registrar Paquete</button>
        </div>
    </div>
</div>

@code {
    [Inject] private UnidadResidencialProject.Services.AuthService AuthService { get; set; } = default!;

    [Parameter] public List<ApartamentoDto> Apartamentos { get; set; } = new();
    [Parameter] public EventCallback<MensajeriaCreateDto> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private string _empresa = "";
    private string _guia = "";
    private int _unidadId = 0;
    private DateTime _fechaRecepcion = DateTime.Now;
    
    // UI Only variables
    private string _residente = "";
    private string _tipo = "Paquete";
    private string _estado = "Pendiente";

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_empresa) || _unidadId <= 0) return;

        var userId = await AuthService.GetUserIdAsync();

        var tipoPrefix = $"[{_tipo}] ";

        var nuevo = new MensajeriaCreateDto
        {
            Empresa = tipoPrefix + _empresa,
            Guia = _guia,
            UnidadId = _unidadId,
            FechaRecepcion = _fechaRecepcion,
            UsuarioId = userId > 0 ? userId : 4 // Default a 4 si falla
        };

        await OnGuardar.InvokeAsync(nuevo);
    }
}
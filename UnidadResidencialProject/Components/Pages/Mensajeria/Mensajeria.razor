@page "/mensajeria"
@using UnidadResidencialProject.Models
@using UnidadResidencialProject.Services
@inject MensajeriaService MensajeriaService

<PageTitle>Mensajería — Conjunto Residencial</PageTitle>

<div class="crm-shell">

    <Sidebar />

    <main class="main-content">

        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Mensajería</h1>
                <span class="page-breadcrumb">Control de paquetes y correspondencia</span>
            </div>
            <div class="topbar-right">
                <button class="btn-primary" @onclick="@(() => _mostrarFormulario = true)">
                    + Registrar Paquete
                </button>
            </div>
        </header>

        <div class="page-body">

            @if (!string.IsNullOrEmpty(_error))
            {
                <div style="background: #fdf2f2; border: 1px solid #f5c2c7; color: #842029; padding: 12px; margin-bottom: 1rem; border-radius: 4px;">
                    <strong>Error:</strong> @_error
                </div>
            }

            <MensajeriaTarjetas Paquetes="@_paquetes" />

            <MensajeriaFiltros
                FiltroEstado="@_filtroEstado"
                TextoBusqueda="@_busqueda"
                OnEstadoChanged="@((e) => _filtroEstado = e)"
                OnBusquedaChanged="@((b) => _busqueda = b)" />

            <MensajeriaTabla
                Paquetes="@PaquetesFiltrados"
                OnMarcarEntregado="@MarcarEntregado" />

        </div>

        @if (_mostrarFormulario)
        {
            <MensajeriaFormulario
                Apartamentos="@_apartamentos"
                OnGuardar="@GuardarPaquete"
                OnCancelar="@(() => _mostrarFormulario = false)" />
        }

    </main>
</div>

@code {
    private bool _mostrarFormulario = false;
    private string _filtroEstado = "Todos";
    private string _busqueda = "";

    private bool _cargando = true;
    private string? _error;

    private List<MensajeriaDto> _paquetes = new();
    private List<ApartamentoDto> _apartamentos = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            _cargando = true;
            _error = null;

            _paquetes = await MensajeriaService.GetMensajeriasAsync();
            _apartamentos = await MensajeriaService.GetApartamentosAsync();
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    private string GetEstado(MensajeriaDto p) => p.FechaEntrega == null ? "Pendiente" : "Entregado";

    // ── Computed ──────────────────────────────────────────
    private List<MensajeriaDto> PaquetesFiltrados =>
        _paquetes
            .Where(p => _filtroEstado == "Todos" || GetEstado(p) == _filtroEstado)
            .Where(p => string.IsNullOrWhiteSpace(_busqueda) ||
                        p.Empresa?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) == true ||
                        p.Guia?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) == true ||
                        p.Unidad?.Numero.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) == true)
            .ToList();

    // ── Acciones ──────────────────────────────────────────
    private async Task MarcarEntregado(int id)
    {
        var idx = _paquetes.FindIndex(p => p.MensajeriaId == id);
        if (idx >= 0)
        {
            var p = _paquetes[idx];
            var fechaOriginal = p.FechaEntrega;
            p.FechaEntrega = DateTime.Now;

            var (ok, error) = await MensajeriaService.ActualizarMensajeriaAsync(id, p);
            if (!ok)
            {
                p.FechaEntrega = fechaOriginal;
                _error = $"Error al entregar: {error}";
            }
        }
    }

    private async Task GuardarPaquete(MensajeriaCreateDto nuevo)
    {
        try
        {
            var (ok, error) = await MensajeriaService.CrearMensajeriaAsync(nuevo);
            if (ok)
            {
                _error = null;
                await CargarDatos();
            }
            else
            {
                _error = $"Error al registrar: {error}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error al guardar: {ex.Message}";
        }
        _mostrarFormulario = false;
    }
}
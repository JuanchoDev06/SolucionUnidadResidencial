@page "/parqueadero"
@using UnidadResidencialProject.Models
@using UnidadResidencialProject.Services
@using UnidadResidencialProject.Components.Pages.Parqueadero.Components
@inject ParqueaderoService ParqueaderoService
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Parqueadero — Conjunto Residencial</PageTitle>

<div class="crm-shell">

    <Sidebar />

    <main class="main-content">

        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Parqueadero</h1>
                <span class="page-breadcrumb">Gestión de cupos · Planta 1 y Planta 2</span>
            </div>
            <div class="topbar-right">
                <button class="btn-secondary" @onclick="@(() => _mostrarFormResidente = true)">
                    ▦ Asignar Cupo Residente
                </button>
                <button class="btn-primary" @onclick="@(() => _mostrarFormVisitante = true)">
                    + Registrar Visitante
                </button>
            </div>
        </header>

        <div class="page-body">

            @if (_cargando)
            {
                <p style="color: var(--text3); font-style: italic;">Cargando información...</p>
            }
            else if (_error != null)
            {
                <div style="color: #DC2626; padding: 1rem;">
                    @_error
                    <button class="btn-primary" style="margin-left: 1rem;" @onclick="CargarDatos">
                        Reintentar
                    </button>
                </div>
            }
            else
            {
                <!-- Stats -->
                <div class="stats-row">
                    <div class="stat-chip green">
                        <span class="stat-num">@_parqueaderos.Count(p => p.UnidadId == null)</span>
                        <span class="stat-lbl">Disponibles</span>
                    </div>
                    <div class="stat-chip blue">
                        <span class="stat-num">@_parqueaderos.Count(p => p.UnidadId != null)</span>
                        <span class="stat-lbl">Residentes</span>
                    </div>
                    <div class="stat-chip red">
                        <span class="stat-num">@_visitantes.Count(v => v.FechaHoraSalida == null)</span>
                        <span class="stat-lbl">Visitantes</span>
                    </div>
                    <div class="stat-chip gray">
                        <span class="stat-num">@_parqueaderos.Count</span>
                        <span class="stat-lbl">Total Cupos</span>
                    </div>
                    <div class="stat-chip amber">
                        <span class="stat-num">@_visitantes.Count(v => v.FechaHoraSalida == null)</span>
                        <span class="stat-lbl">Visitantes activos</span>
                    </div>
                </div>

                <!-- Filtros -->
                <ParqueaderoFiltros FiltroActivo="@_filtro"
                                    OnFiltroChanged="@((f) => _filtro = f)" />

                <!-- Mapa -->
                <ParqueaderoMapa Cupos="@CuposMapeados"
                                 OnLiberarCupo="@LiberarCupo"
                                 OnVerDetalle="@AbrirDetalle" />

                <!-- Historial -->
                <ParqueaderoHistorial Historial="@HistorialMapeado"
                                      OnRegistrarSalida="@RegistrarSalidaVisitante" />
            }

        </div>

        @if (_mostrarFormVisitante)
        {
            <ParqueaderoFormVisitante CuposDisponibles="@(_cuposMapeados.Where(c => c.Estado == "libre").ToList())"
                                      Apartamentos="@_apartamentos"
                                      OnGuardar="@GuardarVisitante"
                                      OnCancelar="@(() => _mostrarFormVisitante = false)" />
        }

        @if (_mostrarFormResidente)
        {
            <ParqueaderoFormResidente CuposDisponibles="@(_cuposMapeados.Where(c => c.Estado == "libre").ToList())"
                                      Apartamentos="@_apartamentos"
                                      OnGuardar="@GuardarAsignacionResidente"
                                      OnCancelar="@(() => _mostrarFormResidente = false)" />
        }

    </main>
</div>

@code {
    private bool _mostrarFormVisitante = false;
    private bool _mostrarFormResidente = false;
    private bool _inicializado = false;
    private string _filtro = "Todos";
    private bool _cargando = true;
    private string? _error;

    private List<ApartamentoDto> _apartamentos = new();
    private List<ParqueaderoDto> _parqueaderos = new();
    private List<ParqueaderoVisitanteDto> _visitantes = new();

    // ── Modelos para los componentes hijos ────────────────
    public record CupoItem(int Id, string Tipo, string Numero,
                       string Estado, string? Residente, string? Placa);

    public record HistorialItem(int Id, int CupoId, string Placa,
                                string NombreVisitante, string Unidad,
                                string FechaHoraIngreso, string? FechaHoraSalida);

    // ── Computed — mapear DTOs a records de los componentes
    private List<CupoItem> _cuposMapeados => _parqueaderos.Select(p =>
{
        var visitanteActivo = _visitantes.FirstOrDefault(v =>
            v.ParqueaderoId == p.ParqueaderoId && v.FechaHoraSalida == null);

        var estado = visitanteActivo != null ? "visitante"
                   : p.UnidadId != null ? "residente"
                   : "libre";

        return new CupoItem(
            p.ParqueaderoId,
            p.Tipo,
            p.Numero,
            estado,
            p.Unidad != null ? $"Apto {p.Unidad.Numero}" : null,
            visitanteActivo?.Placa ?? p.Placa
        );
    }).ToList();

    private List<CupoItem> CuposMapeados => _filtro switch
    {
        "Disponible" => _cuposMapeados.Where(c => c.Estado == "libre").ToList(),
        "Residente" => _cuposMapeados.Where(c => c.Estado == "residente").ToList(),
        "Visitante" => _cuposMapeados.Where(c => c.Estado == "visitante").ToList(),
        _ => _cuposMapeados
    };

    private List<HistorialItem> HistorialMapeado => _visitantes.Select(v => new HistorialItem(
        v.ParqueaderoVisitanteId,
        v.ParqueaderoId,
        v.Placa,
        "Visitante",
        v.Parqueadero != null ? $"Cupo {v.Parqueadero.Numero}" : $"Cupo {v.ParqueaderoId}",
        v.FechaHoraIngreso.ToString("hh:mm tt"),
        v.FechaHoraSalida?.ToString("hh:mm tt")
    )).ToList();

    // ── Ciclo de vida ─────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _inicializado) return;
        _inicializado = true;

        var rol = await AuthService.GetRolAsync();
        if (rol != "Administrador" && rol != "Vigilante")
        {
            Nav.NavigateTo("/dashboard");
            return;
        }

        await CargarDatos();
        StateHasChanged();
    }

    private async Task CargarDatos()
    {
        try
        {
            _cargando = true;
            _error = null;
            _parqueaderos = await ParqueaderoService.GetParqueaderosAsync();
            _visitantes = await ParqueaderoService.GetVisitantesAsync();
            _apartamentos = await ParqueaderoService.GetApartamentosAsync(); // ← solo esto
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    // ── Acciones ──────────────────────────────────────────
    private void LiberarCupo(int id) { /* futuro */ }
    private void AbrirDetalle(int id) { /* futuro */ }

    private async Task GuardarVisitante((int CupoId, string Placa, string Nombre, string Unidad) datos)
    {
        var nuevo = new ParqueaderoVisitanteCreateDto
        {
            ParqueaderoId = datos.CupoId,
            Placa = datos.Placa.ToUpper(),
            FechaHoraIngreso = DateTime.Now
        };

        var (ok, error) = await ParqueaderoService.RegistrarVisitanteAsync(nuevo);
        if (ok)
        {
            _error = null;
            await CargarDatos();
        }
        else
        {
            _error = $"Error al registrar visitante: {error}";
        }
        _mostrarFormVisitante = false;
    }

    private async Task GuardarAsignacionResidente((int CupoId, string Residente, string Placa, int UnidadId) datos)
    {
        var parqueadero = _parqueaderos.FirstOrDefault(p => p.ParqueaderoId == datos.CupoId);
        if (parqueadero == null) return;

        var parqueaderoActualizado = new ParqueaderoDto
        {
            ParqueaderoId = parqueadero.ParqueaderoId,
            Tipo = parqueadero.Tipo,
            Numero = parqueadero.Numero,
            UnidadId = datos.UnidadId > 0 ? datos.UnidadId : null
        };

        var (ok, error) = await ParqueaderoService.ActualizarParqueaderoAsync(
            datos.CupoId, parqueaderoActualizado);

        if (ok)
        {
            _error = null;
            await CargarDatos();
        }
        else
        {
            _error = $"Error al asignar cupo: {error}";
        }
        _mostrarFormResidente = false;
    }

    private async Task RegistrarSalidaVisitante(int id)
    {
        var visitante = _visitantes.FirstOrDefault(v => v.ParqueaderoVisitanteId == id);
        if (visitante == null) return;

        var (ok, error) = await ParqueaderoService.RegistrarSalidaVisitanteAsync(id, visitante);
        if (ok)
        {
            _error = null;
            await CargarDatos();
        }
        else
        {
            _error = $"Error al registrar salida: {error}";
        }
    }
}
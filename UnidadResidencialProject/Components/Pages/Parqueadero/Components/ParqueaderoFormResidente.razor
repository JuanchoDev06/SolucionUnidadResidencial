@using UnidadResidencialProject.Components.Pages.Parqueadero

<div class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Asignar Cupo a Residente</h2>
            <button class="modal-close" @onclick="OnCancelar">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Nombre del Residente</label>
                    <input class="form-control" type="text" placeholder="Ej: Juan Pérez" @bind="_residente" />
                </div>
                <div class="form-group">
                    <label class="form-label">Placa del Vehículo</label>
                    <input class="form-control" type="text" placeholder="Ej: ABC-123" @bind="_placa" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Apartamento</label>
                    <input class="form-control" type="text" placeholder="Ej: Apto 205" @bind="_apto" />
                </div>
                <div class="form-group">
                    <label class="form-label">Cupo a Asignar</label>
                    <select class="form-control" @bind="_cupoId">
                        <option value="0">— Seleccionar cupo —</option>
                        @foreach (var c in CuposDisponibles)
                        {
                            <option value="@c.Id">Cupo @c.Numero — @c.Tipo</option>
                        }
                    </select>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" @onclick="OnCancelar">Cancelar</button>
            <button class="btn-save" @onclick="Guardar">Asignar Cupo</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<Parqueadero.CupoItem> CuposDisponibles { get; set; } = new();
    [Parameter] public EventCallback<(int, string, string)> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private string _residente = "";
    private string _placa = "";
    private string _apto = "";
    private int _cupoId = 0;

    private async Task Guardar()
    {
        if (_cupoId > 0 && !string.IsNullOrWhiteSpace(_residente))
            await OnGuardar.InvokeAsync((_cupoId, $"{_residente} · {_apto}", _placa.ToUpper()));
    }
}
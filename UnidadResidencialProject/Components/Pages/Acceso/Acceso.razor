@page "/ingresos"
@using UnidadResidencialProject.Components.Pages.Acceso.Components
@using UnidadResidencialProject.Components.Pages.Dashboard.Components
@inject IngresoService IngresoService
@inject AuthService AuthService


<PageTitle>Control de Acceso — Conjunto Residencial</PageTitle>

<div class="crm-shell">

    <Sidebar />

    <main class="main-content">

        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Control de Acceso</h1>
                <span class="page-breadcrumb">Registro de ingresos y salidas · Hoy, @DateTime.Now.ToString("dddd d 'de' MMMM yyyy", new System.Globalization.CultureInfo("es-CO"))</span>
            </div>
            <div class="topbar-right">
                <button class="btn-primary" @onclick="AbrirFormulario">
                    + Registrar Ingreso
                </button>
            </div>
        </header>

        <div class="page-body">

            @if (_cargando)
            {
                <div class="stats-row">
                    <p style="color: var(--text3); font-style: italic;">Cargando ingresos…</p>
                </div>
            }
            else if (_error != null)
            {
                <div class="stats-row">
                    <p style="color: #DC2626;">@_error</p>
                    <button class="btn-primary" style="margin-left: 1rem;" @onclick="CargarIngresos">Reintentar</button>
                </div>
            }
            else
            {
                <div class="stats-row">
                    <div class="stat-chip blue">
                        <span class="stat-num">@_ingresos.Count</span>
                        <span class="stat-lbl">Total hoy</span>
                    </div>
                    <div class="stat-chip green">
                        <span class="stat-num">@_ingresos.Count(i => i.Tipo == "Residente")</span>
                        <span class="stat-lbl">Residentes</span>
                    </div>
                    <div class="stat-chip amber">
                        <span class="stat-num">@_ingresos.Count(i => i.Tipo == "Visitante")</span>
                        <span class="stat-lbl">Visitantes</span>
                    </div>
                    <div class="stat-chip purple">
                        <span class="stat-num">@_ingresos.Count(i => i.Tipo == "Proveedor")</span>
                        <span class="stat-lbl">Proveedores</span>
                    </div>
                    <div class="stat-chip red">
                        <span class="stat-num">@_ingresos.Count(i => i.FechaHoraSalida == null)</span>
                        <span class="stat-lbl">Dentro ahora</span>
                    </div>
                </div>

                <AccesoFiltros TipoSeleccionado="@_filtroTipo"
                               OnFiltroChanged="@((t) => { _filtroTipo = t; })" />

                <AccesoTabla Ingresos="@IngresosFiltrados"
                             OnRegistrarSalida="@RegistrarSalida" />
            }

        </div>

        @if (_mostrarFormulario)
        {
            <AccesoFormulario OnGuardar="@GuardarIngreso"
                              OnCancelar="@(() => _mostrarFormulario = false)" />
        }

    </main>
</div>

@code {
    private bool _mostrarFormulario = false;
    private string _filtroTipo = "Todos";
    private bool _cargando = true;
    private string? _error;

    private List<IngresoDto> _ingresos = new();

    private List<IngresoDto> IngresosFiltrados =>
        _filtroTipo == "Todos"
            ? _ingresos
            : _ingresos.Where(i => i.Tipo == _filtroTipo).ToList();

    protected override async Task OnInitializedAsync()
    {
        await CargarIngresos();
    }

    private async Task CargarIngresos()
    {
        try
        {
            _cargando = true;
            _error = null;
            _ingresos = await IngresoService.GetIngresosAsync();
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar ingresos: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    private void AbrirFormulario() => _mostrarFormulario = true;

    private async Task GuardarIngreso(IngresoCreateDto nuevo)
    {
        try
        {
            // Obtener el userId del usuario logueado
            var userId = await AuthService.GetUserIdAsync();
            nuevo.UsuarioId = userId;
            nuevo.FechaHoraIngreso = DateTime.Now;

            var (ok, error) = await IngresoService.CrearIngresoAsync(nuevo);
            if (ok)
            {
                _error = null;
                await CargarIngresos();
            }
            else
            {
                _error = $"Error al guardar el ingreso: {error}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error al guardar: {ex.Message}";
        }

        _mostrarFormulario = false;
    }

    private async Task RegistrarSalida(int id)
    {
        var item = _ingresos.FirstOrDefault(i => i.IngresoId == id);
        if (item != null)
        {
            try
            {
                item.FechaHoraSalida = DateTime.Now;
                var (ok, error) = await IngresoService.ActualizarIngresoAsync(id, item);
                if (ok)
                {
                    _error = null;
                    await CargarIngresos();
                }
                else
                {
                    _error = $"Error al registrar la salida: {error}";
                }
            }
            catch (Exception ex)
            {
                _error = $"Error al registrar salida: {ex.Message}";
            }
        }
    }
}
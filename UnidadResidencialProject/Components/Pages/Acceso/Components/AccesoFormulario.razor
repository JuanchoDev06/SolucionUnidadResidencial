@using UnidadResidencialProject.Models

<div class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Registrar Nuevo Ingreso</h2>
            <button class="modal-close" @onclick="OnCancelar">✕</button>
        </div>

        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Tipo de Ingreso</label>
                    <select class="form-control" @bind="_tipo">
                        <option value="Residente">Residente</option>
                        <option value="Visitante">Visitante</option>
                        <option value="Proveedor">Proveedor</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">ID Unidad</label>
                    <input class="form-control" type="number" placeholder="Ej: 1" @bind="_unidadId" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Nombre Completo</label>
                    <input class="form-control" type="text" placeholder="Ej: Juan Pérez" @bind="_nombre" />
                </div>
                <div class="form-group">
                    <label class="form-label">Documento</label>
                    <input class="form-control" type="text" placeholder="Ej: 80.123.456" @bind="_documento" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Hora de Ingreso</label>
                    <input class="form-control" type="text" value="@DateTime.Now.ToString("hh:mm tt")" readonly />
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn-cancel" @onclick="OnCancelar">Cancelar</button>
            <button class="btn-save" @onclick="Guardar">Guardar Ingreso</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<IngresoCreateDto> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private string _tipo = "Residente";
    private string _nombre = "";
    private string _documento = "";
    private int _unidadId = 0;

    private async Task Guardar()
    {
        var nuevo = new IngresoCreateDto
        {
            Tipo = _tipo,
            NombrePersona = _nombre,
            Documento = _documento,
            FechaHoraIngreso = DateTime.Now,
            UnidadId = _unidadId
        };
        await OnGuardar.InvokeAsync(nuevo);
    }
}
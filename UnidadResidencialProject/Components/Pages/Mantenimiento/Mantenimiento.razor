@page "/mantenimiento"
@using UnidadResidencialProject.Models
@using UnidadResidencialProject.Services
@using UnidadResidencialProject.Components.Pages.Mantenimiento.Components
@inject MantenimientoService MantenimientoService

<PageTitle>Mantenimiento — Conjunto Residencial</PageTitle>

<div class="crm-shell">

    <Sidebar />

    <main class="main-content">

        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Mantenimiento</h1>
                <span class="page-breadcrumb">Gestión de mantenimientos · Zonas comunes y equipos</span>
            </div>
            <div class="topbar-right">
                <button class="btn-primary" @onclick="@(() => _mostrarFormulario = true)">
                    + Registrar Mantenimiento
                </button>
            </div>
        </header>

        <div class="page-body">

            @if (_cargando)
            {
                <p style="color: var(--text3); font-style: italic;">Cargando información...</p>
            }
            else if (_error != null)
            {
                <div style="color: #DC2626; padding: 1rem;">
                    @_error
                    <button class="btn-primary" style="margin-left: 1rem;" @onclick="CargarDatos">
                        Reintentar
                    </button>
                </div>
            }
            else
            {
                <MantenimientoTarjetas Mantenimientos="@_mantenimientos" />

                <MantenimientoFiltros FiltroEstado="@_filtroEstado"
                                      FiltroTipo="@_filtroTipo"
                                      Tipos="@_tipos.Select(t => t.Nombre).ToList()"
                                      OnEstadoChanged="@((e) => _filtroEstado = e)"
                                      OnTipoChanged="@((t) => _filtroTipo = t)" />

                <MantenimientoTabla Mantenimientos="@MantenimientosFiltrados"
                                    OnCambiarEstado="@CambiarEstado" />
            }

        </div>

        @if (_mostrarFormulario)
        {
            <MantenimientoFormulario Tipos="@_tipos"
                                     ZonasComunes="@_zonas"
                                     OnGuardar="@GuardarMantenimiento"
                                     OnCancelar="@(() => _mostrarFormulario = false)" />
        }

    </main>
</div>

@code {
    private bool _mostrarFormulario = false;
    private string _filtroEstado = "Todos";
    private string _filtroTipo = "Todos";
    private bool _cargando = true;
    private string? _error;

    private List<MantenimientoDto> _mantenimientos = new();
    private List<TipoMantenimientoDto> _tipos = new();
    private List<ZonaComunDto> _zonas = new();

    // ── Filtrado directo sobre DTOs ───────────────────────
    private List<MantenimientoDto> MantenimientosFiltrados =>
        _mantenimientos
            .Where(m => _filtroEstado == "Todos" || (m.Estado ?? "Pendiente") == _filtroEstado)
            .Where(m => _filtroTipo == "Todos" || (m.TipoMantenimiento?.Nombre ?? "") == _filtroTipo)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            _cargando = true;
            _error = null;
            _mantenimientos = await MantenimientoService.GetMantenimientosAsync();
            _tipos = await MantenimientoService.GetTiposMantenimientoAsync();
            _zonas = await MantenimientoService.GetZonasComunesAsync();
        }
        catch (Exception ex)
        {
            _error = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task CambiarEstado((int Id, string NuevoEstado) datos)
    {
        var idx = _mantenimientos.FindIndex(m => m.MantenimientoId == datos.Id);
        if (idx < 0) return;

        var estadoAnterior = _mantenimientos[idx].Estado;
        _mantenimientos[idx].Estado = datos.NuevoEstado;

        var (ok, error) = await MantenimientoService.ActualizarMantenimientoAsync(
            datos.Id, _mantenimientos[idx]);

        if (!ok)
        {
            _mantenimientos[idx].Estado = estadoAnterior;
            _error = $"Error al actualizar estado: {error}";
        }
        else
        {
            _error = null;
            await CargarDatos();
        }
    }

    private async Task GuardarMantenimiento(MantenimientoCreateDto dto)
    {
        var (ok, error) = await MantenimientoService.CrearMantenimientoAsync(dto);
        if (ok)
        {
            _error = null;
            await CargarDatos();
        }
        else
        {
            _error = $"Error al registrar mantenimiento: {error}";
        }
        _mostrarFormulario = false;
    }
}
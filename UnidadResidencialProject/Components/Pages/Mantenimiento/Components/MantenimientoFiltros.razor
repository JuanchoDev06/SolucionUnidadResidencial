<div class="filtros-bar">
    <div class="filtros-grupo">
        <span class="filtros-label">Estado:</span>
        @foreach (var estado in _estados)
        {
            <button class="filtro-btn @(FiltroEstado == estado.Key ? "active " + estado.Css : "")"
                    @onclick="@(() => OnEstadoChanged.InvokeAsync(estado.Key))">
                <span class="fdot @estado.Css"></span>
                @estado.Key
            </button>
        }
    </div>
    <div class="filtros-grupo">
        <span class="filtros-label">Tipo:</span>
        <select class="filtro-select" @bind="@_tipoLocal" @bind:after="EmitTipo">
            <option value="Todos">Todos los tipos</option>
            @foreach (var tipo in Tipos)
            {
                <option value="@tipo">@tipo</option>
            }
        </select>
    </div>
</div>

@code {
    [Parameter] public string FiltroEstado { get; set; } = "Todos";
    [Parameter] public string FiltroTipo { get; set; } = "Todos";
    [Parameter] public List<string> Tipos { get; set; } = new();
    [Parameter] public EventCallback<string> OnEstadoChanged { get; set; }
    [Parameter] public EventCallback<string> OnTipoChanged { get; set; }

    private string _tipoLocal = "Todos";

    private record EstadoOption(string Key, string Css);
    private List<EstadoOption> _estados = new()
    {
        new("Todos",      "todos"),
        new("Pendiente",  "pendiente"),
        new("En curso",   "encurso"),
        new("Completado", "completado"),
    };

    private async Task EmitTipo() => await OnTipoChanged.InvokeAsync(_tipoLocal);
}
@using UnidadResidencialProject.Models

<div class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Registrar Mantenimiento</h2>
            <button class="modal-close" @onclick="OnCancelar">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Tipo de Mantenimiento</label>
                    <select class="form-control" @bind="_tipoId">
                        <option value="0">— Seleccionar tipo —</option>
                        @foreach (var t in Tipos)
                        {
                            <option value="@t.TipoMantenimientoId">@t.Nombre</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Zona Común</label>
                    <select class="form-control" @bind="_zonaId">
                        <option value="0">— Seleccionar zona —</option>
                        @foreach (var z in ZonasComunes)
                        {
                            <option value="@z.ZonaComunId">@z.Nombre</option>
                        }
                    </select>
                </div>
            </div>
            <div class="form-group full">
                <label class="form-label">Descripción</label>
                <textarea class="form-control" rows="3"
                          placeholder="Describe el trabajo a realizar..."
                          @bind="_descripcion"></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Proveedor</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: Otis Colombia" @bind="_proveedor" />
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha Programada</label>
                    <input class="form-control" type="date" @bind="_fecha" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Costo Estimado ($)</label>
                    <input class="form-control" type="number"
                           placeholder="Ej: 500000" @bind="_costo" />
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" @onclick="OnCancelar">Cancelar</button>
            <button class="btn-save" @onclick="Guardar">Guardar Mantenimiento</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<TipoMantenimientoDto> Tipos { get; set; } = new();
    [Parameter] public List<ZonaComunDto> ZonasComunes { get; set; } = new();
    [Parameter] public EventCallback<MantenimientoCreateDto> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private int _tipoId = 0;
    private int _zonaId = 0;
    private string _descripcion = "";
    private string _proveedor = "";
    private DateTime _fecha = DateTime.Today.AddDays(3);
    private decimal _costo = 0;
    // Estado inicial en backend (aunque no esté en el create DTO explícitamente se puede manejar en el backend)

    private async Task Guardar()
    {
        if (_tipoId <= 0 || _zonaId <= 0) return;

        var nuevo = new MantenimientoCreateDto
        {
            TipoMantenimientoId = _tipoId,
            ZonaComunId = _zonaId,
            Descripcion = _descripcion,
            Proveedor = _proveedor,
            Fecha = _fecha,
            Costo = _costo
        };

        await OnGuardar.InvokeAsync(nuevo);
    }
}
@using UnidadResidencialProject.Components.Pages.Mantenimiento

<div class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Registrar Mantenimiento</h2>
            <button class="modal-close" @onclick="OnCancelar">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Tipo de Mantenimiento</label>
                    <select class="form-control" @bind="_tipo">
                        <option value="">— Seleccionar tipo —</option>
                        @foreach (var t in Tipos)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Zona Común</label>
                    <select class="form-control" @bind="_zona">
                        <option value="">— Seleccionar zona —</option>
                        @foreach (var z in ZonasComunes)
                        {
                            <option value="@z">@z</option>
                        }
                    </select>
                </div>
            </div>
            <div class="form-group full">
                <label class="form-label">Descripción</label>
                <textarea class="form-control" rows="3"
                          placeholder="Describe el trabajo a realizar..."
                          @bind="_descripcion"></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Proveedor</label>
                    <input class="form-control" type="text"
                           placeholder="Ej: Otis Colombia" @bind="_proveedor" />
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha Programada</label>
                    <input class="form-control" type="date" @bind="_fecha" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Costo Estimado ($)</label>
                    <input class="form-control" type="number"
                           placeholder="Ej: 500000" @bind="_costo" />
                </div>
                <div class="form-group">
                    <label class="form-label">Estado Inicial</label>
                    <select class="form-control" @bind="_estado">
                        <option value="Pendiente">Pendiente</option>
                        <option value="En curso">En curso</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" @onclick="OnCancelar">Cancelar</button>
            <button class="btn-save" @onclick="Guardar">Guardar Mantenimiento</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<string> Tipos { get; set; } = new();
    [Parameter] public List<string> ZonasComunes { get; set; } = new();
    [Parameter] public EventCallback<Mantenimiento.MantenimientoItem> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private string _tipo = "";
    private string _zona = "";
    private string _descripcion = "";
    private string _proveedor = "";
    private DateTime _fecha = DateTime.Today.AddDays(3);
    private decimal _costo = 0;
    private string _estado = "Pendiente";

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_tipo) || string.IsNullOrWhiteSpace(_zona)) return;

        var nuevo = new Mantenimiento.MantenimientoItem(
            0, _tipo, _zona, _descripcion, _proveedor,
            _fecha.ToString("d MMM yyyy"),
            _estado, _costo);

        await OnGuardar.InvokeAsync(nuevo);
    }
}